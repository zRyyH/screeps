{
    "files.exclude": {
        "**/.git": false,
        "**/.svn": false,
        "**/.hg": false,
        "**/.DS_Store": false,
        "**/Thumbs.db": false,
        "**/CVS": false,
        "**/*.git": false,
        "**/.gitignore": false,
        "**/Gruntfile.js": false,
        "**/package-lock.json": false,
        "**/package.json": false,
        "**/node_modules": false,
        "**/.vscode": false
    },
    "explorerExclude.backup": {},
    "python-envs.pythonProjects": [
        {
            "path": ".vscode",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip"
        }
    ]
}